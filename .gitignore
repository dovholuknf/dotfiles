# --- secrets / credentials ---
*.pem
*.key
*.pfx
*.p12
*.pkcs12
*.jks
*.keystore
*.crt
*.cer
id_rsa
id_rsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*
id_dsa
id_dsa.*
*.ppk
known_hosts
authorized_keys

# --- env / dotenv ---
.env
.env.*
!.env.example
!.env.sample

# --- cloud / tool creds ---
.aws/credentials
.azure/
.gcloud/
.kube/config
.docker/config.json
.npmrc
.pypirc
.netrc
_netrc
.git-credentials

# --- powershell secret / history ---
*.psd1.secret
*SecretStore*
*.clixml
PSReadLine/
ConsoleHost_history.txt

# --- shell history / sessions ---
.bash_history
.zsh_history
.psql_history
.mysql_history
.lesshst
.viminfo
.wget-hsts

# --- editor / OS noise ---
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
*.stackdump

# --- local-only overrides ---
*.local
*.local.*
local.*
secrets.*
*.secret
*.secret.*
*private*

# --- build / cache ---
.vs/
.vscode/*.log
node_modules/
__pycache__/
*.pyc

# --- direnv / tooling auto-load ---
.envrc

# --- terraform (state files often have plaintext secrets) ---
*.tfvars
!*.tfvars.example
.terraformrc
terraform.rc
terraform.tfstate
terraform.tfstate.*
.terraform/

# --- gcloud service accounts (very common leak vector) ---
*-key.json
*-credentials.json
serviceAccount*.json
service-account*.json

# --- package-manager auth ---
.yarnrc.yml
.yarnrc
.cargo/credentials
.cargo/credentials.toml
.pip/pip.conf
nuget.config
NuGet.config

# --- gh / glab CLI ---
.config/gh/hosts.yml
.config/glab-cli/

# --- Azure Functions / common appsettings patterns ---
local.settings.json
appsettings.Local.json
appsettings.*.Local.json

# --- VPN / remote-access configs ---
*.ovpn
wireguard.conf
*.wg

# --- password manager exports ---
*.kdbx
*.1pux
*.opvault

# --- repl + shell history not already listed ---
.python_history
.node_repl_history
Microsoft.PowerShell_history

# --- IDE per-user state (paths, history) ---
*.user
.idea/workspace.xml
.idea/tasks.xml
.idea/shelf/
